# Строка подключения к PostgreSQL (заполнится после создания БД на Railway)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Токен твоего Telegram бота (от @BotFather)
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Секретный ключ для admin-панели (придумай сам, любая строка)
ADMIN_KEY=my_secret_admin_key_here

# Окружение
NODE_ENV=production
